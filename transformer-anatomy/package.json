{
  "name": "transformer-anatomy",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "A from-scratch, numerically-verified transformer (trained on tiny-shakespeare) with a live in-browser inference engine and interactive visualizations of every internal stage.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "tsc --noEmit",
    "verify": "node scripts/verify-against-pytorch.cjs"
  },
  "dependencies": {
    "d3": "^7.9.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.13.0"
  },
  "devDependencies": {
    "@types/d3": "^7.4.3",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
